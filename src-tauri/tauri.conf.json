{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GameSaver",
  "version": "0.1.4",
  "identifier": "com.gamesaver.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GameSaver",
        "width": 1080,
        "height": 820,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": [
      "redirector/bin/gamesaver-injector.exe",
      "redirector/bin/gamesaver-hook.dll"
    ]
  }
}
